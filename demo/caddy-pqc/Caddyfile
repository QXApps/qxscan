# Caddyfile — QXScan PQC Demo Fixture
# Canonical "pqc_hybrid=true" test target.
# Uses TLS 1.3 with X25519MLKEM768 hybrid key exchange (PQC-ready).
# auto_https is disabled because we use pre-generated certs.

{
    auto_https off
    debug
}

caddy-pqc {
    tls /certs/caddy-pqc.crt /certs/caddy-pqc.key

    header {
        X-PQC-Enabled "true"
        Strict-Transport-Security "max-age=63072000"
    }

    respond "QXScan PQC Demo — TLS 1.3 with X25519MLKEM768 hybrid key exchange. PQC readiness: A+"
}
